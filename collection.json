                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Tenta criar pedido sem o campo userId.\n\n✅ Demonstra: validação automática — campo obrigatório faltando."
          },
          "response": []
        }
      ]
