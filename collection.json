    {
      "name": "Circuit Breaker",
      "item": [
        {
          "name": "CB 1 — Buscar produto ANTES de derrubar",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/p1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "p1"
              ]
            },
            "description": "Executar ANTES de derrubar o products-service.\nDeve retornar o produto normalmente.\n\n➡️ Próximo passo: rodar no terminal:\ndocker-compose stop products-service"
          },
          "response": []
        },
        {
          "name": "CB 2 — Buscar produto DEPOIS de derrubar (fallback)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/p1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "p1"
              ]
            },
            "description": "Executar DEPOIS de derrubar o products-service.\n\n✅ Demonstra: Circuit Breaker aberto → fallback retorna produto indisponível.\n\nEsperado:\n{\n  \"id\": \"p1\",\n  \"name\": \"Produto Indisponível\",\n  \"cached\": true\n}\n\n➡️ Para restaurar:\ndocker-compose start products-service"
          },
          "response": []
        },
        {
          "name": "CB 3 — Criar pedido com serviço fora",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"p1\",\n  \"quantity\": 1,\n  \"userId\": \"user-42\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Tentar criar pedido com products-service fora do ar.\n\n✅ Demonstra: erro claro em vez de timeout infinito.\nO orders-service falha rápido e retorna mensagem de erro."
          },
          "response": []
        },
        {
          "name": "CB 4 — Buscar produto APÓS restaurar",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/p1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "p1"
              ]
            },
            "description": "Executar APÓS subir o products-service novamente.\n\n✅ Demonstra: Circuit Breaker Half-Open → chamada de teste → volta para Closed.\nRetorna o produto normalmente sem nenhuma intervenção manual."
          },
          "response": []
        }
      ]
    }
