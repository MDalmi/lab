    {
      "name": "Erros e Validações",
      "item": [
        {
          "name": "404 — Produto inexistente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/products/p99",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "p99"
              ]
            },
            "description": "Busca um produto que não existe.\n\n✅ Demonstra: MoleculerClientError com código 404 e type PRODUCT_NOT_FOUND.\n\nEsperado:\n{\n  \"error\": \"Produto 'p99' não encontrado\",\n  \"code\": \"PRODUCT_NOT_FOUND\"\n}"
          },
          "response": []
        },
        {
          "name": "422 — Estoque insuficiente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"p2\",\n  \"quantity\": 999,\n  \"userId\": \"user-42\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Tenta pedir 999 unidades de Mouse Sem Fio (stock: 50).\n\n✅ Demonstra: MoleculerClientError com código 422 e type INSUFFICIENT_STOCK.\n\nEsperado:\n{\n  \"error\": \"Estoque insuficiente para 'Mouse Sem Fio' (disponível: 50)\",\n  \"code\": \"INSUFFICIENT_STOCK\"\n}"
          },
          "response": []
        },
        {
          "name": "422 — Validação de params (quantity negativo)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"p1\",\n  \"quantity\": -5,\n  \"userId\": \"user-42\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Tenta criar pedido com quantity negativo.\n\n✅ Demonstra: validação automática de params pelo Moleculer (fastest-validator).\nO handler nem chega a executar — rejeitado antes."
          },
          "response": []
        },
        {
          "name": "422 — Validação de params (campo faltando)",
          "request": {
